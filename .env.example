# Copy to .env and fill in. The real .env is gitignored.
# These are the variable names the code reads; the values are your secrets.

# Reading chat (Phase 1) — a YouTube Data API key:
YT_API_KEY=your-api-key-here

# OAuth login + sending (Phase 2) — from an OAuth client of type
# "TVs and Limited Input devices". The device flow uses the
# https://www.googleapis.com/auth/youtube scope (force-ssl is not allowed for
# device flow). Leave blank to run read-only; login is disabled until both set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
